<Sysmon schemaversion="4.50">
  <EventFiltering>
    <!-- SYSMON EVENT ID 23 : FILE DELETE -->
    <!-- This monitors for mass deletion of documents and data -->
    <RuleGroup name="AnomalousDeletionDetection" groupRelation="or">
      <FileDelete onmatch="include">
        <!-- Target sensitive directories -->
        <TargetFilename condition="contains">C:\Users</TargetFilename>
        <TargetFilename condition="contains">C:\Sensitive\Data</TargetFilename>
        
        <!-- Target critical file extensions often hit by ransomware/wipers -->
        <TargetFilename condition="end with">.pdf</TargetFilename>
        <TargetFilename condition="end with">.docx</TargetFilename>
        <TargetFilename condition="end with">.xlsx</TargetFilename>
        <TargetFilename condition="end with">.zip</TargetFilename>
        <TargetFilename condition="end with">.exe</TargetFilename>
        <TargetFilename condition="end with">.ps1</TargetFilename>
      </FileDelete>
      
      <!-- EVENT ID 26: FILE DELETE DETECTED (For newer Sysmon versions) -->
      <FileDeleteDetected onmatch="include">
        <TargetFilename condition="contains">C:\Users</TargetFilename>
        <TargetFilename condition="contains">C:\Sensitive\Data</TargetFilename>
      </FileDeleteDetected>
    </RuleGroup>
  </EventFiltering>
</Sysmon>
