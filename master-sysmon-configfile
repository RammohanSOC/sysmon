<Sysmon schemaversion="4.90">
  <HashAlgorithms>md5,sha256</HashAlgorithms>

  <EventFiltering>

    <!-- ============================= -->
    <!-- Privilege Escalation (PsExec-like behavior) -->
    <!-- ============================= -->

    <RuleGroup name="PrivilegeEscalation_PsExec" groupRelation="or">
      <ProcessCreate onmatch="include">
        <ParentImage condition="image">PSEXESVC.exe</ParentImage>
        <Image condition="image">powershell.exe</Image>
        <Image condition="image">cmd.exe</Image>
      </ProcessCreate>

      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">Services\PSEXESVC</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Service Installation Detection -->
    <!-- ============================= -->

    <RuleGroup name="Service_Installation_Detection" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">HKLM\System\CurrentControlSet\Services</TargetObject>
      </RegistryEvent>

      <ProcessCreate onmatch="include">
        <Image condition="end with">sc.exe</Image>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <Image condition="end with">powershell.exe</Image>
        <CommandLine condition="contains">New-Service</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Unauthorized Configuration Change -->
    <!-- ============================= -->

    <RuleGroup name="Registry_Tracking" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">Services\Wazuh</TargetObject>
        <TargetObject condition="contains">Microsoft\Windows Defender</TargetObject>
        <TargetObject condition="contains">System\CurrentControlSet\Control\Lsa</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <RuleGroup name="Config_Tools" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="begin with">C:\Windows\System32\reg.exe</Image>
        <Image condition="begin with">C:\Windows\System32\net.exe</Image>
        <Image condition="begin with">C:\Windows\System32\sc.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Application Installation Detection -->
    <!-- ============================= -->

    <RuleGroup name="ApplicationInstall_ProcessCreate" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="contains">msiexec.exe</Image>
        <Image condition="contains">setup.exe</Image>
        <Image condition="contains">install.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <RuleGroup name="ApplicationInstall_FileCreate" groupRelation="or">
      <FileCreate onmatch="include">
        <TargetFilename condition="contains">Program Files</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <RuleGroup name="ApplicationInstall_Registry" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">CurrentVersion\Uninstall</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- ============================= -->
    <!-- File Deletion Detection -->
    <!-- ============================= -->

    <RuleGroup name="FileDeletionDetection" groupRelation="or">
      <FileDelete onmatch="include">
        <TargetFilename condition="contains">C:\Users</TargetFilename>
        <TargetFilename condition="contains">C:\Sensitive\Data</TargetFilename>
      </FileDelete>

      <FileDeleteDetected onmatch="include">
        <TargetFilename condition="contains">C:\Users</TargetFilename>
        <TargetFilename condition="contains">C:\Sensitive\Data</TargetFilename>
      </FileDeleteDetected>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Unauthorized File Access Detection -->
    <!-- ============================= -->

    <RuleGroup name="SensitiveFileAccess" groupRelation="or">
      <FileCreate onmatch="include">
        <TargetFilename condition="begin with">C:\SensitiveData\</TargetFilename>
      </FileCreate>

      <FileDelete onmatch="include">
        <TargetFilename condition="begin with">C:\SensitiveData\</TargetFilename>
      </FileDelete>

      <FileCreateStreamHash onmatch="include">
        <TargetFilename condition="begin with">C:\SensitiveData\</TargetFilename>
      </FileCreateStreamHash>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Scheduled Task Detection -->
    <!-- ============================= -->

    <RuleGroup name="ScheduledTask_ProcessCreate" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="end with">schtasks.exe</Image>
        <CommandLine condition="contains">/create</CommandLine>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <Image condition="end with">schtasks.exe</Image>
        <CommandLine condition="contains">/change</CommandLine>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <Image condition="end with">schtasks.exe</Image>
        <CommandLine condition="contains">/delete</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <RuleGroup name="ScheduledTask_Execution" groupRelation="or">
      <ProcessCreate onmatch="include">
        <ParentImage condition="end with">taskeng.exe</ParentImage>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <ParentImage condition="end with">svchost.exe</ParentImage>
        <CommandLine condition="contains">Schedule</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <RuleGroup name="ScheduledTask_Registry" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="begin with">HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Schedule\TaskCache\Tree</TargetObject>
      </RegistryEvent>

      <RegistryEvent onmatch="include">
        <TargetObject condition="begin with">HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Schedule\TaskCache\Tasks</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <RuleGroup name="ScheduledTask_FileCreation" groupRelation="or">
      <FileCreate onmatch="include">
        <TargetFilename condition="contains">\Windows\System32\Tasks\</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Suspicious Archive Extraction Detection (NEW) -->
    <!-- ============================= -->

    <RuleGroup name="ArchiveTools_ProcessCreate" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="end with">7z.exe</Image>
        <Image condition="end with">winrar.exe</Image>
        <Image condition="end with">winzip.exe</Image>
        <Image condition="end with">expand.exe</Image>
        <Image condition="end with">tar.exe</Image>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <Image condition="end with">powershell.exe</Image>
        <CommandLine condition="contains">Expand-Archive</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <RuleGroup name="ArchiveExtraction_FileDrop" groupRelation="or">
      <FileCreate onmatch="include">
        <TargetFilename condition="begin with">C:\Windows\Temp</TargetFilename>
      </FileCreate>

      <FileCreate onmatch="include">
        <TargetFilename condition="begin with">C:\Users\</TargetFilename>
        <TargetFilename condition="contains">\AppData\</TargetFilename>
      </FileCreate>

      <FileCreate onmatch="include">
        <TargetFilename condition="end with">.exe</TargetFilename>
      </FileCreate>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
