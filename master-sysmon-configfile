<Sysmon schemaversion="4.90">
  <HashAlgorithms>md5,sha256</HashAlgorithms>

  <EventFiltering>

    <!-- ============================= -->
    <!-- Privilege Escalation (PsExec-like behavior) -->
    <!-- ============================= -->
    <RuleGroup name="PrivilegeEscalation_PsExec" groupRelation="or">
      <ProcessCreate onmatch="include">
        <ParentImage condition="image">PSEXESVC.exe</ParentImage>
        <Image condition="image">powershell.exe</Image>
        <Image condition="image">cmd.exe</Image>
      </ProcessCreate>

      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">Services\PSEXESVC</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Service Installation Detection -->
    <!-- ============================= -->
    <RuleGroup name="Service_Installation_Detection" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">HKLM\System\CurrentControlSet\Services</TargetObject>
      </RegistryEvent>

      <ProcessCreate onmatch="include">
        <Image condition="end with">sc.exe</Image>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <Image condition="end with">powershell.exe</Image>
        <CommandLine condition="contains">New-Service</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <!-- ============================= -->
    <!-- 🌐 VPN Detection (ENHANCED - NEW) -->
    <!-- ============================= -->
    <RuleGroup name="VPN_Detection_Enhanced" groupRelation="or">

      <ProcessCreate onmatch="include">
        <Image condition="contains">openvpn</Image>
        <Image condition="contains">wireguard</Image>
        <Image condition="contains">nordvpn</Image>
        <Image condition="contains">protonvpn</Image>
        <Image condition="contains">expressvpn</Image>
        <Image condition="contains">forticlient</Image>
        <Image condition="contains">anyconnect</Image>
        <Image condition="contains">tailscale</Image>

        <CommandLine condition="contains">--config</CommandLine>
        <CommandLine condition="contains">.ovpn</CommandLine>
      </ProcessCreate>

      <NetworkConnect onmatch="include">
        <Image condition="contains">openvpn</Image>
        <Image condition="contains">wireguard</Image>
        <Image condition="contains">nordvpn</Image>
        <Image condition="contains">protonvpn</Image>
        <Image condition="contains">anyconnect</Image>
        <Image condition="contains">forticlient</Image>

        <DestinationIp condition="is not">127.0.0.1</DestinationIp>
        <DestinationIp condition="is not">10.</DestinationIp>
        <DestinationIp condition="is not">192.168.</DestinationIp>
        <DestinationIp condition="is not">172.</DestinationIp>
      </NetworkConnect>

      <DriverLoad onmatch="include">
        <Signature condition="contains">OpenVPN</Signature>
        <Signature condition="contains">WireGuard</Signature>
        <ImageLoaded condition="contains">tap</ImageLoaded>
        <ImageLoaded condition="contains">tun</ImageLoaded>
        <ImageLoaded condition="contains">wintun</ImageLoaded>
      </DriverLoad>

      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">NetworkSetup2\Interfaces</TargetObject>
      </RegistryEvent>

    </RuleGroup>

    <!-- ============================= -->
    <!-- 🌐 Beaconing Detection -->
    <!-- ============================= -->
    <RuleGroup name="Network_Beaconing_Detection" groupRelation="or">
      <NetworkConnect onmatch="include">

        <Image condition="is not">C:\Windows\System32\svchost.exe</Image>
        <Image condition="is not">C:\Windows\System32\dns.exe</Image>
        <Image condition="is not">C:\Windows\System32\lsass.exe</Image>

        <Image condition="is not">C:\Program Files\Google\Chrome\Application\chrome.exe</Image>
        <Image condition="is not">C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe</Image>

        <DestinationIp condition="is not">127.0.0.1</DestinationIp>
        <DestinationIp condition="is not">::1</DestinationIp>

      </NetworkConnect>
    </RuleGroup>

    <!-- ============================= -->
    <!-- DNS Monitoring -->
    <!-- ============================= -->
    <RuleGroup name="DNS_Query_Monitoring" groupRelation="or">
      <DnsQuery onmatch="include">
        <Image condition="is not">C:\Program Files\Google\Chrome\Application\chrome.exe</Image>
        <Image condition="is not">C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe</Image>
      </DnsQuery>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Registry Tracking -->
    <!-- ============================= -->
    <RuleGroup name="Registry_Tracking" groupRelation="or">
      <RegistryEvent onmatch="include">
        <TargetObject condition="contains">CurrentVersion\Run</TargetObject>
        <TargetObject condition="contains">Services\Wazuh</TargetObject>
        <TargetObject condition="contains">Microsoft\Windows Defender</TargetObject>
        <TargetObject condition="contains">System\CurrentControlSet\Control\Lsa</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Config Tools -->
    <!-- ============================= -->
    <RuleGroup name="Config_Tools" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="begin with">C:\Windows\System32\reg.exe</Image>
        <Image condition="begin with">C:\Windows\System32\net.exe</Image>
        <Image condition="begin with">C:\Windows\System32\sc.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Suspicious PowerShell -->
    <!-- ============================= -->
    <RuleGroup name="PowerShell_Suspicious_Execution" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="end with">powershell.exe</Image>
        <Image condition="end with">pwsh.exe</Image>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <CommandLine condition="contains">-enc</CommandLine>
      </ProcessCreate>

      <ProcessCreate onmatch="include">
        <CommandLine condition="contains">IEX</CommandLine>
      </ProcessCreate>
    </RuleGroup>

    <!-- ============================= -->
    <!-- Credential Dump Detection -->
    <!-- ============================= -->
    <RuleGroup name="CredentialDump_Tools" groupRelation="or">
      <ProcessCreate onmatch="include">
        <Image condition="end with">procdump.exe</Image>
        <Image condition="end with">procdump64.exe</Image>
        <Image condition="end with">mimikatz.exe</Image>
        <Image condition="end with">nanodump.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <RuleGroup name="LSASS_Access" groupRelation="or">
      <ProcessAccess onmatch="include">
        <TargetImage condition="is">C:\Windows\System32\lsass.exe</TargetImage>
      </ProcessAccess>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
