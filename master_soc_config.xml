<Sysmon schemaversion="4.90">
  <!-- GLOBAL SETTINGS: Capturing hashes for CDB List cross-referencing -->
  <HashAlgorithms>MD5,SHA256</HashAlgorithms>
  <CheckRevocation />
  <DnsLookup>True</DnsLookup>

  <EventFiltering>

    <!-- [COVERED: CDB List Detection / PowerShell Monitoring / Privilege Escalation / C2 Indicators] -->
    <RuleGroup name="ProcessMonitoring" groupRelation="or">
      <ProcessCreate onmatch="include">
        <!-- CDB List & Malware: Capturing all process hashes for SIEM lookups -->
        <Image condition="begin with">C:\Users</Image>
        <Image condition="begin with">C:\ProgramData</Image>
        <Image condition="begin with">C:\Windows\Temp</Image>
        
        <!-- Advanced PowerShell Monitoring: Capturing obfuscated/encoded commands -->
        <Image condition="image">powershell.exe</Image>
        <Image condition="image">pwsh.exe</Image>
        <CommandLine condition="contains">-enc</CommandLine>
        <CommandLine condition="contains">bypass</CommandLine>
        
        <!-- Privilege Escalation & C2: Detect system-level tool execution -->
        <User condition="is">NT AUTHORITY\SYSTEM</User>
        <Image condition="image">psexec.exe</Image>
        <Image condition="image">mimikatz.exe</Image>
        <ParentImage condition="image">PSEXESVC.exe</ParentImage>
        
        <!-- New App Installations: Monitor installers running in temp/user dirs -->
        <Image condition="end with">setup.exe</Image>
        <Image condition="end with">install.exe</Image>
      </ProcessCreate>
      
      <ProcessCreate onmatch="exclude">
        <!-- Sophos Integration: Exclude Sophos from process noise -->
        <Image condition="contains">Sophos</Image>
        <Image condition="is">C:\Windows\System32\smss.exe</Image>
      </ProcessCreate>
    </RuleGroup>

    <!-- [COVERED: Port Scanning / Network Reconnaissance / C2 / Remote Access / VPN] -->
    <RuleGroup name="NetworkDetection" groupRelation="or">
      <NetworkConnect onmatch="include">
        <!-- Port Scanning & Recon: Log all outbound connections from interpreters -->
        <Image condition="image">powershell.exe</Image>
        <Image condition="image">cmd.exe</Image>
        <Image condition="image">wscript.exe</Image>
        <!-- Remote Access: Monitor common VPN/RDP ports -->
        <DestinationPort condition="is">3389</DestinationPort>
        <DestinationPort condition="is">443</DestinationPort>
        <DestinationPort condition="is">80</DestinationPort>
      </NetworkConnect>
      
      <NetworkConnect onmatch="exclude">
        <!-- Noise reduction for Azure and standard browsers -->
        <DestinationIp condition="is">168.63.129.16</DestinationIp>
        <Image condition="image">chrome.exe</Image>
        <Image condition="image">msedge.exe</Image>
      </NetworkConnect>
    </RuleGroup>

    <!-- [COVERED: Anomalous File Deletion / FIM / Archive Extraction / USB Activity] -->
    <RuleGroup name="FileAndStorageEvents" groupRelation="or">
      <!-- FIM & Anomalous Deletion (Event ID 23/26) -->
      <FileDelete onmatch="include">
        <TargetFilename condition="contains">C:\Sensitive\Data</TargetFilename>
        <TargetFilename condition="contains">C:\Users</TargetFilename>
      </FileDelete>
      
      <!-- Suspicious Archive Extraction (Event ID 11) -->
      <FileCreate onmatch="include">
        <TargetFilename condition="end with">.zip</TargetFilename>
        <TargetFilename condition="end with">.rar</TargetFilename>
        <TargetFilename condition="end with">.7z</TargetFilename>
        <!-- USB Device Activity: Monitor files created on removable drives (usually D-Z) -->
        <TargetFilename condition="begin with">D:\</TargetFilename>
        <TargetFilename condition="begin with">E:\</TargetFilename>
        <TargetFilename condition="begin with">F:\</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- [COVERED: New Service Installation / Persistence / SCA Context] -->
    <RuleGroup name="PersistenceAndServices" groupRelation="or">
      <RegistryEvent onmatch="include">
        <!-- New Service Installation & Tampering -->
        <TargetObject condition="contains">Services\PSEXESVC</TargetObject>
        <TargetObject condition="contains">CurrentControlSet\Services</TargetObject>
        <!-- Persistence: Run/RunOnce Keys -->
        <TargetObject condition="contains">Microsoft\Windows\CurrentVersion\Run</TargetObject>
        <!-- User Account Creation Context: SAM/LSA Registry Monitoring -->
        <TargetObject condition="contains">SAM\SAM\Domains\Account\Users</TargetObject>
      </RegistryEvent>
    </RuleGroup>

    <!-- [COVERED: USB Device Activity / Driver Monitoring] -->
    <RuleGroup name="HardwareEvents" groupRelation="or">
      <DeviceObjectEvents onmatch="include">
        <!-- Monitoring for unauthorized USB peripheral mounting -->
        <Device condition="begin with">\Device\Harddisk</Device>
      </DeviceObjectEvents>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
